-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0

Bundle-SymbolicName: com.ibm.websphere.javaee.transaction.1.2; singleton:=true

Export-Package: \
	javax.transaction

# Update to import javax.transaction.xa from the jre instead of the buildpath one.
Import-Package: \
	javax.transaction.xa;version=!, \
	*

# this pulls in the partial javax.transaction package from the jre
# and lets us export them.
Require-Bundle: system.bundle

instrument.disabled: true

publish.wlp.jar.suffix: dev/api/spec

-buildpath: \
	javax.transaction:javax.transaction-api;version=1.2

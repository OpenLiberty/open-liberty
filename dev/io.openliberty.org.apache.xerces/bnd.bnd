-include= ~../cnf/resources/bnd/bundle.props
bVersion=2.11.2

#Currently only intended for testing purposes
Bundle-Name: Apache Xerces2-j
Bundle-SymbolicName: io.openliberty.org.apache.xerces
Bundle-Description: Provides XML Commons XML APIs and xercesImpl as a bundle

-includeresource: \
  @${repo;xerces:xercesImpl;2.12.1;EXACT},\
  @${repo;xml-apis:xml-apis;1.4.01;EXACT}!/!javax/*

Export-Package: \
  org.apache.*;version=2.12.1,\
  org.xml.*;version=1.4.01,\
  org.w3c.*;version=1.4.01,\
  org.apache.xmlcommons;version=1.4.01
